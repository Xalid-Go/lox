{
  "name": "lox-cinema",
  "version": "1.0.0",
  "description": "LOX - Co-watching movie platform",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "server:dev": "nodemon server.js",
    "client:dev": "vite src --port 5173",
    "build": "vite build src --outDir ../dist --emptyOutDir",
    "preview": "vite preview src",
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\""
  },
  "dependencies": {
    "express": "^4.19.2",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "hls.js": "^1.5.8",
    "nodemon": "^3.1.0",
    "vite": "^5.2.11"
  }
}
